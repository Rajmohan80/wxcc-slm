# AbhavTech WxCC SLM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Claude API key (Anthropic) — production LLM stack
# Used by: slm_pipeline.py (Haiku 4.5 for classification, Sonnet 4.6 for generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq API key — current runtime LLM (Llama-3.3-70B)
# Used by: slm_pipeline.py (_get_groq_client, _classify_groq, _generate_groq)
# Also checked by api_server.py startup health check
GROQ_API_KEY=your_groq_api_key_here

# ── Vector DB ─────────────────────────────────────────────────────────────────
# Qdrant Cloud cluster URL (e.g. https://abc123.us-east4-0.gcp.cloud.qdrant.io)
QDRANT_URL=your_qdrant_cluster_url_here

# Qdrant API key
QDRANT_KEY=your_qdrant_api_key_here

# Collection name (default: wxcc_slm_corpus)
QDRANT_COLLECTION=wxcc_slm_corpus

# ── Auth (demo) ───────────────────────────────────────────────────────────────
# JWT secret for demo auth simulation
# Replace with proper OAuth 2.0 for production
JWT_SECRET=change_this_to_a_random_32_char_string

# ── n8n Automation (Phase 7) ──────────────────────────────────────────────────
# n8n webhook URL for change approval (Workflow 3)
N8N_APPROVAL_WEBHOOK_URL=https://your-n8n-instance/webhook/approve-change

# Slack bot token for alerts (Workflows 2, 3, 4)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Slack channel for WxCC SLM alerts
SLACK_ALERT_CHANNEL=#wxcc-slm-alerts

# ── Observability ─────────────────────────────────────────────────────────────
# MLflow tracking URI (default: local ./mlruns)
MLFLOW_TRACKING_URI=./mlruns

# ── GCP (production) ──────────────────────────────────────────────────────────
# Only needed for production Cloud Run deployment
# GCP_PROJECT_ID=abhavtech-wxcc-slm
# GCP_REGION=asia-south1
